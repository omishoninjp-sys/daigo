{%- comment -%}
  GOYOUTATI 站內搜尋 section v4（搜尋邏輯不變）
  v4：熱門分類改為「圖文磚」block（圖片 + 分類名，點了即搜）。
      - 有 category block → 顯示圖文磚
      - 沒有 block 但有 hot_categories 文字 → fallback 顯示文字 chips（換檔不開天窗）
      - 熱門搜尋維持文字 chips（hot_searches）
  搜尋/候補/來源/結果/代購 JS 與前版相同。
{%- endcomment -%}

{%- assign uid = section.id -%}

<style>
  #gpds-{{ uid }}{ --navy:#1e2d5a; --gold:#f0a500; max-width:1100px; margin:0 auto; padding:24px 16px; box-sizing:border-box; }
  #gpds-{{ uid }} *{ box-sizing:border-box; }
  #gpds-{{ uid }} .gpds-h{ color:var(--navy); font-size:24px; font-weight:700; margin:0 0 6px; }
  #gpds-{{ uid }} .gpds-sub{ color:#666; font-size:14px; margin:0 0 14px; }
  #gpds-{{ uid }} .gpds-hint{ font-size:12.5px; color:#999; margin:0 0 12px; }
  #gpds-{{ uid }} .gpds-trust{ display:flex; flex-wrap:wrap; gap:8px; margin:0 0 16px; }
  #gpds-{{ uid }} .gpds-trust span{ display:inline-flex; align-items:center; gap:5px; font-size:12.5px; color:#555; background:#f3f5fa; border:1px solid #e3e7f1; border-radius:999px; padding:5px 11px; }
  #gpds-{{ uid }} .gpds-trust span::before{ content:'\2713'; color:var(--navy); font-weight:700; }
  #gpds-{{ uid }} .gpds-bar{ display:flex; gap:8px; margin-bottom:10px; }
  #gpds-{{ uid }} .gpds-inwrap{ position:relative; flex:1; }
  #gpds-{{ uid }} .gpds-input{ width:100%; height:44px; border:1px solid #ccc; border-radius:8px; padding:0 14px; font-size:15px; }
  #gpds-{{ uid }} .gpds-input:focus{ outline:none; border-color:var(--navy); }
  #gpds-{{ uid }} .gpds-btn{ height:44px; padding:0 22px; background:var(--navy); color:#fff; border:none; border-radius:8px; font-size:15px; font-weight:600; cursor:pointer; }
  #gpds-{{ uid }} .gpds-btn:disabled{ opacity:.55; cursor:default; }
  #gpds-{{ uid }} .gpds-sug{ position:absolute; left:0; right:0; top:48px; z-index:30; background:#fff; border:1px solid var(--navy); border-radius:8px; box-shadow:0 6px 20px rgba(0,0,0,.1); overflow:hidden; display:none; }
  #gpds-{{ uid }} .gpds-sug-h{ padding:7px 14px; font-size:12px; color:#999; }
  #gpds-{{ uid }} .gpds-sug-row{ display:flex; align-items:center; gap:10px; padding:9px 14px; cursor:pointer; border-top:1px solid #f0f0f0; }
  #gpds-{{ uid }} .gpds-sug-row:hover{ background:rgba(30,45,90,.06); }
  #gpds-{{ uid }} .gpds-sug-zh{ font-size:15px; color:#222; }
  #gpds-{{ uid }} .gpds-sug-jp{ margin-left:auto; font-size:13px; color:#888; }
  #gpds-{{ uid }} .gpds-srcs{ display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px; }
  #gpds-{{ uid }} .gpds-src{ font-size:13px; padding:6px 16px; border-radius:999px; border:1px solid #ccc; background:#fff; color:#666; cursor:pointer; }
  #gpds-{{ uid }} .gpds-src .gpds-src-note{ color:#aaa; font-size:11px; margin-left:5px; }
  #gpds-{{ uid }} .gpds-src.on{ background:var(--navy); color:#fff; border-color:var(--navy); }
  #gpds-{{ uid }} .gpds-src.on .gpds-src-note{ color:#c8d0e6; }
  #gpds-{{ uid }} .gpds-info{ font-size:13px; color:#666; margin:0 0 14px; display:none; }
  #gpds-{{ uid }} .gpds-info b{ color:var(--navy); font-weight:600; }
  #gpds-{{ uid }} .gpds-guide{ margin:6px 0 10px; }
  #gpds-{{ uid }} .gpds-guide-label{ font-size:13px; color:#888; font-weight:600; margin:16px 0 9px; }
  #gpds-{{ uid }} .gpds-guide-label:first-child{ margin-top:4px; }
  #gpds-{{ uid }} .gpds-chips{ display:flex; flex-wrap:wrap; gap:8px; }
  #gpds-{{ uid }} .gpds-chip{ font-size:14px; color:var(--navy); background:#eef1f9; border:1px solid #d7dded; border-radius:999px; padding:8px 15px; cursor:pointer; transition:background .15s,color .15s,border-color .15s; }
  #gpds-{{ uid }} .gpds-chip:hover{ background:var(--navy); color:#fff; border-color:var(--navy); }
  #gpds-{{ uid }} .gpds-cats{ display:grid; grid-template-columns:repeat(auto-fill,minmax(108px,1fr)); gap:12px; margin-bottom:4px; }
  #gpds-{{ uid }} .gpds-cat{ cursor:pointer; text-align:center; }
  #gpds-{{ uid }} .gpds-cat-img{ aspect-ratio:1/1; border-radius:12px; overflow:hidden; background:#eef1f9; border:1px solid #e3e7f1; display:flex; align-items:center; justify-content:center; transition:border-color .15s,box-shadow .15s,transform .15s; }
  #gpds-{{ uid }} .gpds-cat:hover .gpds-cat-img{ border-color:var(--navy); box-shadow:0 6px 16px rgba(30,45,90,.12); transform:translateY(-2px); }
  #gpds-{{ uid }} .gpds-cat-img img{ width:100%; height:100%; object-fit:cover; }
  #gpds-{{ uid }} .gpds-cat-ph{ color:#b9c1d8; }
  #gpds-{{ uid }} .gpds-cat-label{ margin-top:7px; font-size:13.5px; font-weight:600; color:var(--navy); }
  #gpds-{{ uid }} .gpds-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:14px; }
  #gpds-{{ uid }} .gpds-card{ border:1px solid #eee; border-radius:12px; overflow:hidden; background:#fff; display:flex; flex-direction:column; }
  #gpds-{{ uid }} .gpds-imgwrap{ aspect-ratio:1/1; background:#f5f5f5; position:relative; }
  #gpds-{{ uid }} .gpds-imgwrap img{ width:100%; height:100%; object-fit:contain; }
  #gpds-{{ uid }} .gpds-oos{ position:absolute; top:8px; left:8px; background:#777; color:#fff; font-size:11px; padding:2px 8px; border-radius:4px; }
  #gpds-{{ uid }} .gpds-body{ padding:10px 12px; display:flex; flex-direction:column; gap:6px; flex:1; }
  #gpds-{{ uid }} .gpds-title{ font-size:13px; line-height:1.45; color:#222; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; min-height:54px; }
  #gpds-{{ uid }} .gpds-price{ color:var(--navy); font-size:17px; font-weight:700; }
  #gpds-{{ uid }} .gpds-twd{ color:#888; font-size:12px; font-weight:400; margin-left:6px; }
  #gpds-{{ uid }} .gpds-buy{ margin-top:auto; width:100%; background:var(--gold); color:var(--navy); border:none; border-radius:8px; padding:9px 0; font-size:14px; font-weight:700; cursor:pointer; }
  #gpds-{{ uid }} .gpds-buy:disabled{ opacity:.6; cursor:default; }
  #gpds-{{ uid }} .gpds-msg{ text-align:center; color:#888; font-size:14px; padding:30px 0; }
  #gpds-{{ uid }} .gpds-more{ display:block; margin:22px auto 0; height:42px; padding:0 28px; background:#fff; color:var(--navy); border:1px solid var(--navy); border-radius:8px; font-size:14px; font-weight:600; cursor:pointer; }
  #gpds-{{ uid }} .gpds-seo{ max-width:760px; margin:36px auto 0; border-top:1px solid #eee; padding-top:22px; }
  #gpds-{{ uid }} .gpds-seo h3{ font-size:16px; color:var(--navy); font-weight:700; margin:0 0 8px; }
  #gpds-{{ uid }} .gpds-seo p{ font-size:13.5px; color:#555; line-height:1.85; margin:0 0 14px; }
  #gpds-{{ uid }} .gpds-seo-links{ display:flex; flex-wrap:wrap; gap:7px; }
  #gpds-{{ uid }} .gpds-seo-links a{ font-size:12.5px; color:var(--navy); text-decoration:none; background:#f3f5fa; border:1px solid #e3e7f1; border-radius:14px; padding:5px 12px; }
  #gpds-{{ uid }} .gpds-seo-links a:hover{ background:var(--navy); color:#fff; }
  #gpds-{{ uid }} .gpds-credit{ text-align:center; color:#aaa; font-size:11px; margin:22px 0 0; }
  @media (max-width:600px){
    #gpds-{{ uid }} .gpds-grid{ grid-template-columns:repeat(2,1fr); gap:10px; }
    #gpds-{{ uid }} .gpds-cats{ grid-template-columns:repeat(3,1fr); gap:10px; }
  }
</style>

<div id="gpds-{{ uid }}"
     data-api-base="{{ section.settings.api_base }}"
     data-api-key="{{ section.settings.api_key }}"
     data-source="{{ section.settings.default_source }}"
     data-hits="{{ section.settings.hits }}">

  {%- if section.settings.heading != blank -%}
    <h2 class="gpds-h">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p class="gpds-sub">{{ section.settings.subheading }}</p>
  {%- endif -%}

  <div class="gpds-bar">
    <div class="gpds-inwrap">
      <input class="gpds-input" type="text" autocomplete="off"
             placeholder="貼上商品連結，或輸入關鍵字搜尋（例：鋼彈、Snow Peak）" />
      <div class="gpds-sug" data-role="sug"></div>
    </div>
    <button class="gpds-btn" data-act="search">搜尋</button>
  </div>

  {%- if section.settings.input_hint != blank -%}
    <p class="gpds-hint">{{ section.settings.input_hint }}</p>
  {%- endif -%}

  <div class="gpds-srcs">
    <button class="gpds-src on" data-src="rakuten">日本樂天<span class="gpds-src-note">全站</span></button>
    <button class="gpds-src" data-src="amiami">amiami<span class="gpds-src-note">動漫週邊</span></button>
    <button class="gpds-src" data-src="zozo">ZOZOTOWN<span class="gpds-src-note">服飾</span></button>
  </div>

  <div class="gpds-trust">
    <span>包稅空運</span>
    <span>7–14 個工作天</span>
    <span>50+ 平台</span>
    <span>不用懂日文</span>
  </div>

  <p class="gpds-info" data-role="info"></p>

  <div class="gpds-guide" data-role="guide">
    {%- assign cat_blocks = section.blocks | where: 'type', 'category' -%}
    {%- if cat_blocks.size > 0 -%}
      <div class="gpds-guide-label">熱門分類</div>
      <div class="gpds-cats">
        {%- for block in cat_blocks -%}
          {%- assign term = block.settings.term | default: block.settings.label -%}
          <div class="gpds-cat" data-term="{{ term | escape }}" {{ block.shopify_attributes }}>
            <div class="gpds-cat-img">
              {%- if block.settings.image -%}
                {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: block.settings.label }}
              {%- else -%}
                <svg class="gpds-cat-ph" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              {%- endif -%}
            </div>
            <div class="gpds-cat-label">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- elsif section.settings.hot_categories != blank -%}
      <div class="gpds-guide-label">熱門分類</div>
      <div class="gpds-chips">
        {%- assign cats = section.settings.hot_categories | split: ',' -%}
        {%- for c in cats -%}
          {%- assign cc = c | strip -%}
          {%- if cc != blank -%}<span class="gpds-chip" data-term="{{ cc | escape }}">{{ cc }}</span>{%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.hot_searches != blank -%}
      <div class="gpds-guide-label">熱門搜尋</div>
      <div class="gpds-chips">
        {%- assign hots = section.settings.hot_searches | split: ',' -%}
        {%- for h in hots -%}
          {%- assign hh = h | strip -%}
          {%- if hh != blank -%}<span class="gpds-chip" data-term="{{ hh | escape }}">{{ hh }}</span>{%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="gpds-grid"></div>
  <div class="gpds-msg" data-role="msg" style="display:none;"></div>
  <button class="gpds-more" data-act="more" style="display:none;">載入更多</button>

  {%- if section.settings.seo_heading != blank or section.settings.seo_body != blank -%}
    <div class="gpds-seo">
      {%- if section.settings.seo_heading != blank -%}<h3>{{ section.settings.seo_heading }}</h3>{%- endif -%}
      {%- if section.settings.seo_body != blank -%}<p>{{ section.settings.seo_body }}</p>{%- endif -%}
      <div class="gpds-seo-links">
        <a href="/pages/%E6%97%A5%E6%9C%AC%E4%BB%A3%E8%B3%BC-%E4%B8%80%E6%A2%9D%E9%80%A3%E7%B5%90-%E9%80%81%E5%88%B0%E4%BD%A0%E5%AE%B6">貼連結代購</a>
        <a href="/pages/bape-%E6%97%A5%E6%9C%AC%E4%BB%A3%E8%B3%BC">BAPE 代購</a>
        <a href="/pages/human-made-%E6%97%A5%E6%9C%AC%E4%BB%A3%E8%B3%BC">Human Made 代購</a>
        <a href="/pages/zozotown-%E6%97%A5%E6%9C%AC%E4%BB%A3%E8%B3%BC">ZOZOTOWN 代購</a>
        <a href="/pages/amazon%E6%97%A5%E6%9C%AC%E4%BB%A3%E8%B3%BC">Amazon JP 代購</a>
        <a href="https://goyoutati-shipping.zeabur.app/">日本集運</a>
      </div>
    </div>
  {%- endif -%}

  <p class="gpds-credit">資料來源：楽天ウェブサービス／Yahoo!ショッピング（Web Services by Yahoo! JAPAN）</p>
</div>

<script>
(function(){
  var root = document.getElementById('gpds-{{ uid }}');
  if(!root) return;

  var API_BASE = (root.dataset.apiBase || '').replace(/\/+$/,'');
  var API_KEY  = root.dataset.apiKey || '';
  var source   = root.dataset.source || 'rakuten';
  var HITS     = parseInt(root.dataset.hits || '24', 10) || 24;

  var input = root.querySelector('.gpds-input');
  var grid  = root.querySelector('.gpds-grid');
  var msg   = root.querySelector('[data-role="msg"]');
  var info  = root.querySelector('[data-role="info"]');
  var sug   = root.querySelector('[data-role="sug"]');
  var guide = root.querySelector('[data-role="guide"]');
  var moreBtn = root.querySelector('[data-act="more"]');
  var searchBtn = root.querySelector('[data-act="search"]');

  var page = 1, lastQuery = '', lastTranslate = true, busy = false;
  var sugTimer = null, sugSeq = 0, sugCache = {};

  function yen(n){ return '\u00a5' + Number(n).toLocaleString('ja-JP'); }
  function twd(n){ return '\u2248 NT$' + Number(n).toLocaleString('en-US'); }
  function esc(s){ var d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }
  function hasCJK(s){ return /[\u4e00-\u9fff]/.test(s); }
  function hasKana(s){ return /[\u3040-\u30ff]/.test(s); }
  function isUrl(s){ return /^https?:\/\//i.test((s||'').trim()); }
  function setMsg(t){ msg.textContent = t; msg.style.display = t ? 'block' : 'none'; }
  function hideSug(){ sug.style.display = 'none'; sug.innerHTML = ''; }
  function hideGuide(){ if(guide) guide.style.display = 'none'; }

  // 綁定引導區（圖文分類磚 + 文字 chips）點擊 → 帶入搜尋
  function bindGuide(){
    if(!guide) return;
    guide.querySelectorAll('.gpds-cat, .gpds-chip').forEach(function(el){
      el.addEventListener('click', function(){
        var term = el.getAttribute('data-term') || '';
        if(!term) return;
        input.value = term;
        hideSug();
        runSearch(true, true);
      });
    });
  }
  bindGuide();

  input.addEventListener('input', function(){
    var v = input.value.trim();
    clearTimeout(sugTimer);
    // 貼到的是商品連結 → 切換按鈕字樣、收掉關鍵字候補
    if(isUrl(v)){ searchBtn.textContent = '解析連結'; hideSug(); return; }
    searchBtn.textContent = '搜尋';
    if(!v || hasKana(v) || !hasCJK(v)){ hideSug(); return; }
    if(sugCache[v] !== undefined){ sugCache[v].length ? renderSug(sugCache[v]) : hideSug(); return; }
    sugTimer = setTimeout(function(){ fetchSug(v); }, 300);
  });
  input.addEventListener('keydown', function(e){
    if(e.key === 'Enter'){ hideSug(); runSearch(true, true); }
    else if(e.key === 'Escape'){ hideSug(); }
  });
  document.addEventListener('click', function(e){ if(!root.contains(e.target)) hideSug(); });

  function fetchSug(v){
    var seq = ++sugSeq;
    fetch(API_BASE + '/api/suggest', {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'x-api-key':API_KEY },
      body: JSON.stringify({ query: v })
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if(seq !== sugSeq) return;
      var list = (d && d.success && d.suggestions) ? d.suggestions : [];
      sugCache[v] = list;
      if(input.value.trim() !== v) return;
      if(!list.length){ hideSug(); return; }
      renderSug(list);
    })
    .catch(function(){ hideSug(); });
  }

  function renderSug(list){
    var html = '<div class="gpds-sug-h">你要找哪一種？（點選用日文搜尋）</div>';
    list.forEach(function(s){
      html += '<div class="gpds-sug-row" data-jp="' + esc(s.keyword_jp) + '">' +
                '<span class="gpds-sug-zh">' + esc(s.label_zh) + '</span>' +
                '<span class="gpds-sug-jp">' + esc(s.keyword_jp) + '</span>' +
              '</div>';
    });
    sug.innerHTML = html;
    sug.style.display = 'block';
    sug.querySelectorAll('.gpds-sug-row').forEach(function(row){
      row.addEventListener('click', function(){
        input.value = row.dataset.jp;
        hideSug();
        runSearch(true, false);
      });
    });
  }

  root.querySelectorAll('.gpds-src').forEach(function(b){
    b.addEventListener('click', function(){
      root.querySelectorAll('.gpds-src').forEach(function(x){ x.classList.remove('on'); });
      b.classList.add('on');
      source = b.dataset.src;
      if(lastQuery){ runSearchRaw(true, lastQuery, lastTranslate); }
    });
  });
  searchBtn.addEventListener('click', function(){ hideSug(); runSearch(true, true); });
  moreBtn.addEventListener('click', function(){ runSearchRaw(false, lastQuery, lastTranslate); });

  function runSearch(reset, translate){
    var q = input.value.trim();
    if(!q){ setMsg('請先輸入關鍵字，或貼上商品連結'); return; }
    if(isUrl(q)){ runLink(q); return; }   // ← 貼連結：直接解析該網站商品
    runSearchRaw(reset, q, translate);
  }

  // 貼連結 → 呼叫 /api/scrape 解析單一商品，渲染成一張結果卡（沿用 card / 代購流程）
  function runLink(url){
    if(busy) return;
    busy = true; searchBtn.disabled = true;
    page = 1; grid.innerHTML = ''; moreBtn.style.display = 'none';
    if(info) info.style.display = 'none';
    hideGuide(); hideSug();
    setMsg('解析連結中…（約 10–30 秒，請稍候）');
    fetch(API_BASE + '/api/scrape', {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'x-api-key':API_KEY },
      body: JSON.stringify({ url: url })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      busy = false; searchBtn.disabled = false;
      if(!data || !data.success){
        setMsg((data && (data.error || data.detail)) || '無法從這個連結取得商品，請確認網址是否正確，或改用關鍵字搜尋');
        return;
      }
      var p = data.product || {};
      var pr = data.pricing || {};
      var imgUrl = p.image_url || (p.image_base64 ? ('data:image/jpeg;base64,' + p.image_base64) : '');
      var it = {
        title: p.title || '商品',
        selling_price_jpy: pr.selling_price_jpy || null,
        reference_price_twd: pr.reference_price_twd || null,
        image_url: imgUrl,
        source_url: p.source_url || url,
        in_stock: (p.in_stock !== false)
      };
      setMsg('');
      grid.appendChild(card(it));
    })
    .catch(function(){ busy = false; searchBtn.disabled = false; setMsg('連線失敗，請稍後再試'); });
  }

  function runSearchRaw(reset, q, translate){
    if(!q || busy) return;
    if(reset){ page = 1; grid.innerHTML = ''; lastQuery = q; lastTranslate = translate; hideGuide(); }
    busy = true; searchBtn.disabled = true; moreBtn.style.display = 'none';
    if(reset) setMsg('搜尋中…');

    fetch(API_BASE + '/api/search', {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'x-api-key':API_KEY },
      body: JSON.stringify({ query: q, source: source, hits: HITS, page: page, translate: translate })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      busy = false; searchBtn.disabled = false;
      if(!data || !data.success){ setMsg((data && data.error) || '搜尋失敗，請稍後再試'); return; }
      if(reset){
        var sq = data.searched_query || '';
        if(sq && sq !== data.query){
          info.innerHTML = '搜尋關鍵字：<b>' + esc(sq) + '</b>（自動翻譯自「' + esc(data.query) + '」）';
          info.style.display = 'block';
        } else {
          info.style.display = 'none';
        }
      }
      if(reset && (!data.results || data.results.length === 0)){ setMsg('找不到符合的商品，換個關鍵字試試'); return; }
      setMsg('');
      (data.results || []).forEach(function(it){ grid.appendChild(card(it)); });
      moreBtn.style.display = (data.results && data.results.length >= HITS) ? 'block' : 'none';
      page += 1;
    })
    .catch(function(){ busy = false; searchBtn.disabled = false; setMsg('連線失敗，請稍後再試'); });
  }

  function card(it){
    var el = document.createElement('div');
    el.className = 'gpds-card';
    var price = it.selling_price_jpy ? yen(it.selling_price_jpy) : '\u2014';
    var twdStr = it.reference_price_twd ? '<span class="gpds-twd">' + twd(it.reference_price_twd) + '</span>' : '';
    var oos = it.in_stock ? '' : '<span class="gpds-oos">缺貨</span>';
    var img = it.image_url ? '<img loading="lazy" src="' + esc(it.image_url) + '" alt="">' : '';
    el.innerHTML =
      '<div class="gpds-imgwrap">' + img + oos + '</div>' +
      '<div class="gpds-body">' +
        '<div class="gpds-title">' + esc(it.title) + '</div>' +
        '<div><span class="gpds-price">' + price + '</span>' + twdStr + '</div>' +
        '<button class="gpds-buy">代購此商品</button>' +
      '</div>';
    el.querySelector('.gpds-buy').addEventListener('click', function(e){ buy(it, e.target); });
    return el;
  }

  function buy(it, btn){
    if(btn.disabled) return;
    btn.disabled = true;
    var orig = btn.textContent;
    btn.textContent = '建立中…請稍候';
    fetch(API_BASE + '/api/create-order', {
      method:'POST',
      headers:{ 'Content-Type':'application/json', 'x-api-key':API_KEY },
      body: JSON.stringify({ url: it.source_url })
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if(data && data.success && data.checkout_url){
        window.location.href = data.checkout_url;
      } else {
        btn.disabled = false; btn.textContent = orig;
        alert((data && data.error) || '建立失敗，請稍後再試或改用貼連結');
      }
    })
    .catch(function(){ btn.disabled = false; btn.textContent = orig; alert('連線失敗，請稍後再試'); });
  }
})();
</script>

