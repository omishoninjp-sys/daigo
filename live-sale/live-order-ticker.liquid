{% comment %}
  snippets/live-order-ticker.liquid
  
  使用方式：在 section 或 layout 中 {% render 'live-order-ticker' %}
  
  需要在 Shopify Theme Settings 設定：
    live_ticker_api_url  →  你的 Zeabur API 網址，例如 https://your-app.zeabur.app/api/recent-orders
{% endcomment %}

{%- assign api_url = settings.live_ticker_api_url -%}

<div id="gyt-ticker-wrap" aria-live="polite" aria-label="即時購買通知">
  <span class="gyt-live-dot" aria-hidden="true"></span>
  <span class="gyt-live-label">LIVE</span>
  <div class="gyt-card-slot" id="gytCardSlot">
    <div class="gyt-card gyt-card--active" id="gytInitCard">
      <span class="gyt-icon">🛍️</span>
      <span class="gyt-text">載入中…</span>
    </div>
  </div>
  <div class="gyt-progress" id="gytProgress"></div>
</div>

<style>
  #gyt-ticker-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #1a2744;
    border-top: 1px solid #c9a84c;
    border-bottom: 1px solid #c9a84c;
    padding: 14px 24px;
    overflow: hidden;
    min-height: 56px;
    font-family: "Noto Serif TC", "Noto Serif SC", Georgia, serif;
  }

  .gyt-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4CAF50;
    flex-shrink: 0;
    animation: gyt-blink 1.4s infinite;
  }

  .gyt-live-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: #c9a84c;
    flex-shrink: 0;
    font-weight: 600;
  }

  .gyt-card-slot {
    flex: 1;
    position: relative;
    height: 28px;
    overflow: hidden;
  }

  .gyt-card {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.45s ease, transform 0.45s ease;
    white-space: nowrap;
  }

  .gyt-card--active {
    opacity: 1;
    transform: translateY(0);
  }

  .gyt-card--exit {
    opacity: 0;
    transform: translateY(-10px);
  }

  .gyt-icon {
    font-size: 17px;
    flex-shrink: 0;
  }

  .gyt-flag {
    font-size: 16px;
    flex-shrink: 0;
  }

  .gyt-text {
    color: #f5f0e8;
    font-size: 13.5px;
    letter-spacing: 0.2px;
  }

  .gyt-text .gyt-region {
    color: #e2c27a;
    font-weight: 600;
  }

  .gyt-text .gyt-product {
    color: #ffffff;
  }

  .gyt-text .gyt-ago {
    color: #7a8fa8;
    font-size: 12px;
    margin-left: 6px;
  }

  .gyt-progress {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    background: #c9a84c;
    opacity: 0.5;
    width: 0;
    transition: none;
  }

  @keyframes gyt-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.15; }
  }

  /* 手機版字體縮小 */
  @media (max-width: 480px) {
    #gyt-ticker-wrap { padding: 12px 16px; }
    .gyt-text { font-size: 12px; }
    .gyt-live-label { display: none; }
  }
</style>

<script>
(function () {
  var API_URL = {{ api_url | json }};
  var DURATION = 4500; // ms per card
  var orders = [];
  var idx = 0;
  var slot = document.getElementById('gytCardSlot');
  var progress = document.getElementById('gytProgress');
  var cards = [];
  var timer = null;

  /* ── 建立卡片 DOM ── */
  function buildCards(data) {
    slot.innerHTML = '';
    cards = [];
    data.forEach(function (o, i) {
      var div = document.createElement('div');
      div.className = 'gyt-card' + (i === 0 ? ' gyt-card--active' : '');
      div.innerHTML =
        '<span class="gyt-flag">' + o.flag + '</span>' +
        '<span class="gyt-text">' +
          '<span class="gyt-region">' + o.region + '</span>' +
          '的顧客購買了 ' +
          '<span class="gyt-product">「' + o.product + '」</span>' +
          '<span class="gyt-ago">' + o.time + '</span>' +
        '</span>';
      slot.appendChild(div);
      cards.push(div);
    });
    idx = 0;
  }

  /* ── 進度條 ── */
  function runProgress() {
    progress.style.transition = 'none';
    progress.style.width = '0%';
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        progress.style.transition = 'width ' + DURATION + 'ms linear';
        progress.style.width = '100%';
      });
    });
  }

  /* ── 換卡片 ── */
  function advance() {
    var current = cards[idx];
    current.classList.remove('gyt-card--active');
    current.classList.add('gyt-card--exit');
    setTimeout(function () { current.classList.remove('gyt-card--exit'); }, 500);

    idx = (idx + 1) % cards.length;
    cards[idx].classList.add('gyt-card--active');
    runProgress();
  }

  /* ── 抓 API ── */
  function load() {
    if (!API_URL) return;
    fetch(API_URL)
      .then(function (r) { return r.json(); })
      .then(function (json) {
        if (json.orders && json.orders.length > 0) {
          buildCards(json.orders);
          runProgress();
          if (timer) clearInterval(timer);
          timer = setInterval(advance, DURATION);
        }
      })
      .catch(function () { /* 失敗靜默處理 */ });
  }

  load();
  // 每 2 分鐘重新抓（配合後端快取週期）
  setInterval(load, 120000);
})();
</script>
